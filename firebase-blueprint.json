{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product for sale.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "unit": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "discount": { "type": "number" },
        "description": { "type": "string" }
      },
      "required": ["name", "price", "unit", "category", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "phone", "email", "address", "items", "total", "status", "createdAt"]
    },
    "Subscriber": {
      "title": "Subscriber",
      "description": "A newsletter subscriber.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Collection of products available for sale."
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders."
    },
    "subscribers/{subId}": {
      "schema": "Subscriber",
      "description": "Collection of newsletter subscribers."
    }
  }
}
